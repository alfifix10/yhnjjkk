# ============================================
# TrendScope - Environment Variables
# ============================================
# انسخ هذا الملف وسمّه .env ثم املأ القيم

# --- RapidAPI (لجلب بيانات تيك توك) ---
# سجّل مجاناً في https://rapidapi.com
# ثم اشترك في: https://rapidapi.com/tikapi-tikapi-default/api/tiktok-api23
RAPIDAPI_KEY=your_rapidapi_key_here

# --- Google Gemini API (لتوليد المقالات) ---
# احصل على مفتاح مجاني من: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# --- Supabase (قاعدة البيانات) ---
# أنشئ مشروع مجاني في: https://supabase.com
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# --- إعدادات عامة ---
# مدة تحديث الترندات بالدقائق
UPDATE_INTERVAL_MINUTES=60
