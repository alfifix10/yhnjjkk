{
  "rules": {
    "online": {
      ".read": true,
      "$uid": {
        ".write": true,
        ".validate": "newData.hasChildren(['name', 't']) && newData.child('name').isString() && newData.child('name').val().length <= 20"
      }
    },
    "geo": {
      ".read": true,
      "$uid": {
        ".write": true
      }
    },
    "msgs": {
      "$recipientId": {
        ".read": true,
        "$msgId": {
          ".write": true,
          ".validate": "newData.hasChildren(['from', 'name', 'text', 't']) && newData.child('text').isString() && newData.child('text').val().length <= 500"
        }
      }
    },
    "typing": {
      "$uid1": {
        "$uid2": {
          ".read": true,
          ".write": true
        }
      }
    },
    "logs": {
      ".read": true,
      "$msgId": {
        ".write": true
      }
    },
    "$other": {
      ".read": false,
      ".write": false
    }
  }
}
